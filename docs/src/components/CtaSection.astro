---
import { siteMeta } from "../data/site";
---

<section class="cta">
  <div class="shell cta__inner">
    <h2>Ready to Beam?</h2>
    <p>
      Beam is open source and release-driven. Start with Homebrew, inspect the
      changelog, and ship short-lived links without cloud clutter.
    </p>
    <div class="cta__actions">
      <a class="button button--inverse" href={siteMeta.repository}>
        Get Started on GitHub _
      </a>
      <a class="button button--ghost" href={siteMeta.releases}>
        View Releases
      </a>
    </div>
  </div>
</section>
